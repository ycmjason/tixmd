{
  "name": "@tixmd/web",
  "version": "0.0.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/ycmjason/tixmd"
  },
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "./server": {
        "types": "./dist/server/server.d.ts",
        "default": "./dist/server/server.js"
      }
    }
  },
  "dependencies": {
    "@lexical/code": "catalog:",
    "@lexical/link": "catalog:",
    "@lexical/list": "catalog:",
    "@lexical/markdown": "catalog:",
    "@lexical/react": "catalog:",
    "@lexical/rich-text": "catalog:",
    "@tixmd/core": "workspace:*",
    "lexical": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "vite": "catalog:"
  }
}
