{
  "name": "@tixmd/cli",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/ycmjason/tixmd"
  },

  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "vitest"
  },
  "bin": {
    "tixmd": "./src/bin.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./bin": "./src/bin.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true,
    "bin": {
      "tixmd": "./dist/bin.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./bin": "./dist/bin.js"
    }
  },
  "dependencies": {
    "@tixmd/core": "workspace:*",
    "@tixmd/web": "workspace:*"
  },
  "devDependencies": {}
}
